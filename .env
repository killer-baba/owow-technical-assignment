# ─────────────────────────────────────────────
#  MongoDB
# ─────────────────────────────────────────────
MONGO_URI=mongodb://admin:admin123@localhost:27017
MONGO_DB=conversations
MONGO_COLLECTION_CONVERSATIONS=raw_conversations
MONGO_COLLECTION_DLQ=dead_letter_queue

# ─────────────────────────────────────────────
#  Redis
# ─────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis123
REDIS_TTL_SECONDS=300

# ─────────────────────────────────────────────
#  Neo4j
# ─────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j123

# ─────────────────────────────────────────────
#  Milvus
# ─────────────────────────────────────────────
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION=user_embeddings
MILVUS_DIM=1024

# ─────────────────────────────────────────────
#  SQLite (local analytics mock)
# ─────────────────────────────────────────────
SQLITE_PATH=./data/analytics.db

# ─────────────────────────────────────────────
#  Embedding model
# ─────────────────────────────────────────────
EMBEDDING_MODEL=intfloat/e5-large-v2

# ─────────────────────────────────────────────
#  Pipeline
# ─────────────────────────────────────────────
PIPELINE_BATCH_SIZE=32
LOG_LEVEL=INFO